# Tasks.md - Markdown-based task manager
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# User/group IDs
SERVICE_USER=1000
SERVICE_GROUP=1000

# App display name
APP_NAME=My Tasks

# Cleanup interval in minutes
LOCAL_IMAGES_CLEANUP_INTERVAL=1440
